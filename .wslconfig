# ============================================================
# WSL2 内存限制配置 (Windows 专属)
# ============================================================
# 此文件实际应放在 C:\Users\<你的用户名>\ 目录下！
# 放置后需要重启 WSL2 生效: wsl --shutdown
# ============================================================

[wsl2]
# 限制 WSL2 最大内存使用为 8GB
memory=8GB

# 限制交换内存大小为 4GB
swap=4GB

# 设置虚拟内存页面文件路径
# swapfile=C:\\temp\\wsl-swap.vhdx

# 网络模式 (可选: mirrored 模式可让 WSL2 使用与 Windows 相同的网络)
# networkingMode=mirrored
